# 蝴蝶效应 —— 环境变量配置模板
# 复制为 .env 并填入真实值（.env 已在 .gitignore 中，不会提交到 Git）

# ── 必填：剧情生成 ──────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选：覆盖默认 LLM 端点与模型（默认使用 DeepSeek）
# LLM_API_URL=https://api.deepseek.com/v1/chat/completions
# LLM_MODEL=deepseek-chat

# ── 可选：概念图生成（火山方舟 Ark）────────────────────────────────────────
# 未填写时游戏正常运行，到配图节点时跳过并提示
# ARK_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ARK_MODEL=doubao-seedream-4-0-250828

# ── 可选：机器人自身 open_id ────────────────────────────────────────────────
# 用于过滤机器人自回声；lark-cli compact 事件包含 sender_type 时不需要此项
# FEISHU_BOT_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
